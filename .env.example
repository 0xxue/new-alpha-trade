# Copy this file to `.env` and adjust. None of these are secrets —
# real credentials (Binance cookies / 2FA) live in the SQLite DB, never in env.

# ============ shared ============
# SQLite database path (created on first run)
DB_PATH=../data/new-alpha-trade.db

# ============ trading-engine (Rust) ============
# HTTP/WS listen port
PORT=7002
# Where the qr-service is reachable
QR_SERVICE_URL=http://127.0.0.1:7001

# ============ qr-service (Python) ============
# NOTE: qr-service reads its own PORT (default 7001). If you run both services
# on one host, set this in the qr-service process environment only.
# PORT=7001

# QR screenshot output dir (polled by the frontend)
QR_DIR=../data/qr
# Face-verification QR output dir
FACE_QR_DIR=../data/face_qr
# Persistent Playwright browser profile dir
PLAYWRIGHT_STATE_DIR=../data/playwright-state
# Run the headless browser (true in prod; set false to watch it locally)
PLAYWRIGHT_HEADLESS=true
# Background token health-probe interval (seconds)
REFRESH_INTERVAL_S=3600
